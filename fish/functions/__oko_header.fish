function __oko_header --description 'Department of Operations and Control banner'
    set -l red (set_color -o red)
    set -l yellow (set_color yellow)
    set -l dim (set_color brblack)
    set -l reset (set_color normal)
    echo ""
    echo -e "$redв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—$reset"
    echo -e "$redв•‘$reset $yellow РһРўР”Р•Рӣ РһРҹР•Р РҗРҰРҳРҷ Рҳ РҡРһРқРўР РһРӣРҜ В· Р”РһРҡРЈРңР•РқРўР« РҹРһР–РҗРӣРЈРҷРЎРўРҗ  $reset       $redв•‘$reset"
    echo -e "$redв•‘$reset $dim Departamento de OperaГ§Гөes e Controle              $reset       $redв•‘$reset"
    echo -e "$redв•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ$reset"
end
